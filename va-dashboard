// ====== HELPERS ======
const fmtBig = n => {
  if (n >= 1e6) return (n/1e6).toFixed(2) + 'M';
  if (n >= 1e3) return Math.round(n/1e3) + 'K';
  return n.toString();
};
const fmtFull = n => n.toLocaleString('en-GB');
const pct = n => n.toFixed(1) + '%';

