// ====== SCROLL REVEAL ======
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('in');
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

document.querySelectorAll('.reveal:not(.in)').forEach(el => io.observe(el));

// ====== CHART + COUNT-UP ANIMATIONS ON VIEWPORT ENTRY ======
const chartObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    if (el.id === 'vmSpark' || el.id === 'o2Spark') {
      animateSparkline(el);
    } else if (el.id === 'trendChart') {
      animateTrend();
    } else if (el.dataset.countup) {
      const job = countUpJobs.find(j => j.id === el.id);
      if (job) countUp(el, job.target, 1600, job.fmt);
    }
    chartObserver.unobserve(el);
  });
}, { threshold: 0.3 });

['vmSpark', 'o2Spark', 'trendChart'].forEach(id => {
  const el = document.getElementById(id);
  if (el) chartObserver.observe(el);
});

// Trigger hero/KPI count-ups immediately on load (they're already visible),
// and observe the rest for scroll-triggered counting.
const heroIds = ['heroTotal', 'heroContainedInline', 'heroPctInline'];
const delayedHeroIds = ['kContained', 'kRate', 'kApr', 'vmTotal', 'vmPct', 'o2Total', 'o2Pct'];

heroIds.forEach((id, i) => {
  const el = document.getElementById(id);
  const job = countUpJobs.find(j => j.id === id);
  if (el && job) {
    setTimeout(() => countUp(el, job.target, 1800, job.fmt), 300 + i * 120);
  }
});
delayedHeroIds.forEach(id => {
  const el = document.getElementById(id);
  if (el) {
    el.dataset.countup = '1';
    chartObserver.observe(el);
  }
});
