// ====== SPARKLINES ======
function drawSparkline(svgId, values, color) {
  const svg = document.getElementById(svgId);
  const W = 600, H = 120, pad = 10;
  const min = Math.min(...values) - 2;
  const max = Math.max(...values) + 2;
  const xStep = (W - pad*2) / (values.length - 1);
  const pointsArr = values.map((v, i) => {
    const x = pad + i * xStep;
    const y = pad + (H - pad*2) * (1 - (v - min) / (max - min));
    return [x, y];
  });
  const points = pointsArr.map(p => `${p[0]},${p[1]}`).join(' ');

  const firstX = pad;
  const lastX = pad + (values.length-1) * xStep;
  const areaPath = `M ${firstX},${H} L ${points.split(' ').join(' L ')} L ${lastX},${H} Z`;

  const uid = svgId + '-' + Math.random().toString(36).slice(2, 7);

  let html = `
    <defs>
      <linearGradient id="grad-${uid}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="${color}" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
      </linearGradient>
      <clipPath id="clip-${uid}">
        <rect x="0" y="0" width="0" height="${H}" class="spark-clip" data-target-w="${W}"/>
      </clipPath>
    </defs>
    <g clip-path="url(#clip-${uid})">
      <path d="${areaPath}" fill="url(#grad-${uid})"/>
      <polyline points="${points}" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
  `;
  pointsArr.forEach(([x, y], i) => {
    html += `<circle cx="${x}" cy="${y}" r="3.5" fill="${color}" class="spark-dot" style="opacity:0"/>`;
    if (i === pointsArr.length - 1) {
      html += `<text x="${x - 8}" y="${y - 12}" text-anchor="end" fill="${color}" font-family="Inter" font-weight="700" font-size="14" class="spark-label" style="opacity:0">${values[i].toFixed(1)}%</text>`;
    }
  });
  html += `</g>`;
  svg.innerHTML = html;
}
drawSparkline('vmSpark', DATA.vm.pct, '#bb0a00');
drawSparkline('o2Spark', DATA.o2.pct, '#005EB8');

function animateSparkline(svgEl) {
  if (svgEl.dataset.animated) return;
  svgEl.dataset.animated = '1';
  const clip = svgEl.querySelector('.spark-clip');
  const dots = svgEl.querySelectorAll('.spark-dot');
  const label = svgEl.querySelector('.spark-label');
  if (!clip) return;
  const targetW = parseFloat(clip.getAttribute('data-target-w'));
  const duration = 1400;
  const start = performance.now();
  function tick(now) {
    const t = Math.min(1, (now - start) / duration);
    const eased = 1 - Math.pow(1 - t, 3);
    clip.setAttribute('width', String(targetW * eased));
    dots.forEach((dot, i) => {
      const trig = (i + 1) / dots.length;
      if (eased >= trig) {
        dot.style.transition = 'opacity 0.25s';
        dot.style.opacity = '1';
      }
    });
    if (label && eased >= 0.82) {
      label.style.transition = 'opacity 0.35s';
      label.style.opacity = '1';
    }
    if (t < 1) requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
}

// ====== TREND CHART ======
function drawTrend() {
  const svg = document.getElementById('trendChart');
  const W = 900, H = 380;
  const padL = 60, padR = 40, padT = 30, padB = 50;
  const months = DATA.vm.months;

  const allVals = [...DATA.vm.pct, ...DATA.o2.pct, ...DATA.total.pct];
  const minY = Math.floor(Math.min(...allVals) - 2);
  const maxY = Math.ceil(Math.max(...allVals) + 2);

  const xStep = (W - padL - padR) / (months.length - 1);
  const yScale = v => padT + (H - padT - padB) * (1 - (v - minY) / (maxY - minY));
  const xScale = i => padL + i * xStep;

  let html = '';

  // Y gridlines — fade in
  const ySteps = 5;
  for (let i = 0; i <= ySteps; i++) {
    const yVal = minY + ((maxY - minY) * i / ySteps);
    const y = yScale(yVal);
    html += `<line x1="${padL}" y1="${y}" x2="${W-padR}" y2="${y}" stroke="rgba(255,255,255,0.06)" stroke-width="1" class="trend-grid" style="opacity:0"/>`;
    html += `<text x="${padL - 12}" y="${y + 4}" text-anchor="end" fill="rgba(255,255,255,0.4)" font-family="Inter" font-size="11" font-weight="500" class="trend-axis" style="opacity:0">${yVal.toFixed(0)}%</text>`;
  }

  // X labels
  months.forEach((m, i) => {
    html += `<text x="${xScale(i)}" y="${H - padB + 24}" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-family="Inter" font-size="12" font-weight="600" letter-spacing="1" class="trend-axis" style="opacity:0">${m.toUpperCase()}</text>`;
  });

  // Helper: build a polyline path + its length so we can animate draw-on
  function buildLine(values, color, strokeW, dasharray, lineClass) {
    const ptsStr = values.map((v,i) => `${xScale(i)},${yScale(v)}`).join(' ');
    // convert the polyline points into a path so getTotalLength works reliably
    const d = values.map((v,i) => (i === 0 ? 'M' : 'L') + xScale(i) + ',' + yScale(v)).join(' ');
    let s = `<path d="${d}" fill="none" stroke="${color}" stroke-width="${strokeW}" stroke-linecap="round" stroke-linejoin="round"${dasharray ? ` stroke-dasharray="${dasharray}"` : ''} class="${lineClass}"/>`;
    values.forEach((v,i) => {
      s += `<circle cx="${xScale(i)}" cy="${yScale(v)}" r="${strokeW+1.5}" fill="${color}" class="trend-dot" data-line="${lineClass}" data-idx="${i}" style="opacity:0"/>`;
    });
    return s;
  }

  // Combined behind
  html += buildLine(DATA.total.pct, 'rgba(255,255,255,0.25)', 2, '4 4', 'trend-line-combined');
  // O2
  html += buildLine(DATA.o2.pct, '#005EB8', 3, null, 'trend-line-o2');
  // VM
  html += buildLine(DATA.vm.pct, '#bb0a00', 3, null, 'trend-line-vm');

  const lastI = months.length - 1;
  html += `<text x="${xScale(lastI) + 12}" y="${yScale(DATA.vm.pct[lastI]) + 4}" fill="#bb0a00" font-family="Inter" font-size="13" font-weight="700" class="trend-endlabel" style="opacity:0">${DATA.vm.pct[lastI].toFixed(1)}%</text>`;
  html += `<text x="${xScale(lastI) + 12}" y="${yScale(DATA.o2.pct[lastI]) + 4}" fill="#005EB8" font-family="Inter" font-size="13" font-weight="700" class="trend-endlabel" style="opacity:0">${DATA.o2.pct[lastI].toFixed(1)}%</text>`;

  svg.innerHTML = html;

  // Prime path dash offsets so the lines start hidden
  ['trend-line-combined','trend-line-o2','trend-line-vm'].forEach(cls => {
    const path = svg.querySelector('.' + cls);
    if (!path) return;
    const len = path.getTotalLength();
    // keep the dasharray for the combined line (dashed style); for solid lines we override via offset tricks
    if (cls === 'trend-line-combined') {
      // for dashed line, animate a wrapping clip rect instead
      path.dataset.len = len;
      path.style.opacity = '0';
    } else {
      path.style.strokeDasharray = len;
      path.style.strokeDashoffset = len;
    }
  });
}
drawTrend();

function animateTrend() {
  const svg = document.getElementById('trendChart');
  if (!svg || svg.dataset.animated) return;
  svg.dataset.animated = '1';

  // 1) fade in gridlines + axis labels
  svg.querySelectorAll('.trend-grid, .trend-axis').forEach((el, i) => {
    el.style.transition = 'opacity 0.5s ease';
    el.style.transitionDelay = (i * 0.02) + 's';
    requestAnimationFrame(() => { el.style.opacity = el.classList.contains('trend-grid') ? '1' : '1'; });
  });

  // 2) draw each line in sequence
  const lineOrder = [
    { cls: 'trend-line-combined', delay: 200, duration: 900 },
    { cls: 'trend-line-o2',       delay: 450, duration: 1400 },
    { cls: 'trend-line-vm',       delay: 700, duration: 1400 },
  ];

  lineOrder.forEach(({ cls, delay, duration }) => {
    const path = svg.querySelector('.' + cls);
    if (!path) return;

    if (cls === 'trend-line-combined') {
      // dashed combined line: fade it in rather than draw (dasharray is used for dashes)
      setTimeout(() => {
        path.style.transition = `opacity ${duration}ms ease`;
        path.style.opacity = '1';
      }, delay);
    } else {
      setTimeout(() => {
        path.style.transition = `stroke-dashoffset ${duration}ms cubic-bezier(0.65, 0, 0.35, 1)`;
        path.style.strokeDashoffset = '0';
      }, delay);
    }

    // fade in dots along with the line progress
    const dots = svg.querySelectorAll(`.trend-dot[data-line="${cls}"]`);
    dots.forEach((dot, i) => {
      const dotDelay = delay + (duration * (i / Math.max(1, dots.length - 1))) * 0.9;
      setTimeout(() => {
        dot.style.transition = 'opacity 0.25s ease';
        dot.style.opacity = '1';
      }, dotDelay);
    });
  });

  // 3) end labels fade in after VM line finishes
  svg.querySelectorAll('.trend-endlabel').forEach(el => {
    setTimeout(() => {
      el.style.transition = 'opacity 0.4s ease';
      el.style.opacity = '1';
    }, 700 + 1400 - 100);
  });
}

// ====== L3 TABLE ======
function renderTable(bodyId, rows, nameKey) {
  const body = document.getElementById(bodyId);
  const maxVol = Math.max(...rows.map(r => r.total));
  rows.forEach((r, i) => {
    const up = r.mom > 0;
    const arrow = up ? '↑' : r.mom < 0 ? '↓' : '→';
    const momClass = up ? 'up' : r.mom < 0 ? 'down' : '';
    const shortName = r[nameKey].replace(/^(VM|O2) - /, '');
    const tr = document.createElement('tr');
    tr.className = 't-row';
    tr.dataset.delay = (0.1 + i * 0.04);
    tr.innerHTML = `
      <td>
        <span class="rank">${String(i+1).padStart(2,'0')}</span>
        <span class="brand-tag">${r.brand}</span>
        <span class="intent-name">${shortName}</span>
      </td>
      <td class="r">
        <div class="inline-bar-wrap">
          <span class="t-volume" data-target="${r.total}">0</span>
          <div class="inline-bar"><div class="fill" style="width: ${(r.total/maxVol)*100}%; --delay: ${0.1 + i*0.04}s;"></div></div>
        </div>
      </td>
      <td class="r"><span class="pct-val t-fade" data-target="${r.pct}" data-suffix="%">0.0%</span></td>
      <td class="r"><span class="mom-val t-fade ${momClass}" data-target="${Math.abs(r.mom)}" data-prefix="${arrow} " data-suffix=" pp">${arrow} 0.0 pp</span></td>
    `;
    body.appendChild(tr);
  });
}
renderTable('l3Body', DATA.l3_top, 'intent');
renderTable('flowBody', DATA.flow_top, 'flow');

// Table row observer: count-up + fade-in when row enters view
const tableObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const row = e.target;
    const rowDelay = parseFloat(row.dataset.delay || 0) * 1000;

    // volume count-up
    const vol = row.querySelector('.t-volume');
    if (vol && !vol.dataset.rowDone) {
      vol.dataset.rowDone = '1';
      const target = parseFloat(vol.dataset.target);
      setTimeout(() => countUp(vol, target, 1200, v => fmtFull(Math.round(v))), rowDelay);
    }

    // fade-in values
    row.querySelectorAll('.t-fade').forEach(el => {
      if (el.dataset.rowDone) return;
      el.dataset.rowDone = '1';
      const target = parseFloat(el.dataset.target);
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      setTimeout(() => {
        el.style.transition = 'opacity 0.4s ease';
        el.style.opacity = '0';
        requestAnimationFrame(() => {
          el.style.opacity = '1';
          countUp(el, target, 900, v => prefix + v.toFixed(1) + suffix);
        });
      }, rowDelay + 400);
    });

    tableObserver.unobserve(row);
  });
}, { threshold: 0.35 });

document.querySelectorAll('.t-row').forEach(row => tableObserver.observe(row));

