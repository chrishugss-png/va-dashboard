<style>
  :root {
    --black: #000000;
    --white: #FFFFFF;
    --blue: #005EB8;
    --red: #bb0a00;
    --grey-10: rgba(255, 255, 255, 0.04);
    --grey-20: rgba(255, 255, 255, 0.08);
    --grey-40: rgba(255, 255, 255, 0.16);
    --grey-60: rgba(255, 255, 255, 0.40);
    --grey-80: rgba(255, 255, 255, 0.64);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Inter', system-ui, sans-serif;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    letter-spacing: -0.01em;
    overflow-x: hidden;
  }

  .page {
    max-width: 1320px;
    margin: 0 auto;
    padding: 80px 48px 120px;
  }

  /* ===== TYPOGRAPHY ===== */
  .eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--grey-60);
  }

  h1.display {
    font-size: clamp(56px, 10vw, 144px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin-top: 24px;
  }
  h1.display .blue {
    color: var(--blue);
  }
  h1.display .red {
    color: var(--red);
  }

  h2.section {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.035em;
  }
  h2.section .dim {
    color: var(--grey-40);
  }

  h3 {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-80);
  }

  .lede {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.5;
    font-weight: 400;
    color: var(--grey-80);
    max-width: 720px;
    margin-top: 32px;
    letter-spacing: -0.015em;
  }

  /* ===== SCROLL REVEAL ===== */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--delay, 0s);
  }
  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== HERO ===== */
  .hero {
    min-height: 82vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--grey-20);
  }

  .hero-meta {
    display: flex;
    gap: 48px;
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid var(--grey-20);
    flex-wrap: wrap;
  }
  .hero-meta .item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hero-meta .k {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--grey-60);
  }
  .hero-meta .v {
    font-size: 15px;
    font-weight: 500;
    color: var(--white);
  }

  /* ===== NUMBER BLOCKS ===== */
  section {
    padding-top: 120px;
  }

  .big-number {
    font-size: clamp(120px, 18vw, 240px);
    font-weight: 800;
    line-height: 0.85;
    letter-spacing: -0.05em;
    font-feature-settings: "tnum" 1;
  }
  .big-number .unit {
    font-size: 0.28em;
    font-weight: 600;
    color: var(--grey-60);
    letter-spacing: -0.02em;
    margin-left: 0.15em;
    vertical-align: top;
    margin-top: 0.3em;
    display: inline-block;
  }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--grey-20);
    margin-top: 64px;
  }
  .kpi-grid .cell {
    background: var(--black);
    padding: 48px 32px;
  }
  .kpi-grid .label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--grey-60);
    margin-bottom: 20px;
  }
  .kpi-grid .num {
    font-size: clamp(48px, 5vw, 72px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.035em;
    font-feature-settings: "tnum" 1;
  }
  .kpi-grid .num .u {
    font-size: 0.35em;
    font-weight: 500;
    color: var(--grey-60);
    margin-left: 0.1em;
  }
  .kpi-grid .sub {
    font-size: 13px;
    color: var(--grey-60);
    margin-top: 14px;
    letter-spacing: -0.005em;
  }

  /* ===== BRAND COMPARISON ===== */
  .brand-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--grey-20);
    margin-top: 64px;
  }
  .brand-block {
    background: var(--black);
    padding: 64px 48px;
    position: relative;
  }
  .brand-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 48px;
    height: 3px;
    background: var(--accent, var(--white));
  }
  .brand-block.vm::before { background: var(--red); }
  .brand-block.o2::before { background: var(--blue); }
  .brand-block .name {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--grey-60);
    margin-bottom: 32px;
  }
  .brand-block .total {
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.04em;
  }
  .brand-block .tag {
    font-size: 12px;
    color: var(--grey-60);
    margin-top: 8px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .brand-block .containment-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid var(--grey-20);
  }
  .brand-block .pct-big {
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .brand-block .pct-label {
    font-size: 13px;
    color: var(--grey-60);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ===== SPARKLINE ===== */
  .sparkline-block {
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid var(--grey-20);
  }
  .sparkline-block svg {
    width: 100%;
    height: 120px;
    display: block;
  }
  .sparkline-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grey-60);
  }

  /* ===== MONTHLY TREND ===== */
  .trend-wrap {
    margin-top: 64px;
    padding: 48px;
    border: 1px solid var(--grey-20);
  }
  .trend-wrap .legend {
    display: flex;
    gap: 32px;
    margin-bottom: 32px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--grey-80);
  }
  .legend-dot {
    display: inline-block;
    width: 10px; height: 10px;
    margin-right: 8px;
    vertical-align: middle;
  }
  .trend-svg {
    width: 100%;
    height: 380px;
  }

  /* ===== TABLE ===== */
  .table-wrap {
    margin-top: 64px;
  }
  .t-table {
    width: 100%;
    border-collapse: collapse;
  }
  .t-table thead th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--grey-60);
    padding: 16px 12px;
    border-bottom: 1px solid var(--grey-40);
  }
  .t-table thead th.r { text-align: right; }
  .t-table tbody td {
    padding: 24px 12px;
    border-bottom: 1px solid var(--grey-20);
    font-size: 15px;
    font-feature-settings: "tnum" 1;
  }
  .t-table tbody td.r { text-align: right; }
  .t-table tbody tr:hover td { background: var(--grey-10); }

  .rank {
    font-size: 11px;
    font-weight: 600;
    color: var(--grey-60);
    margin-right: 16px;
    display: inline-block;
    width: 24px;
  }
  .intent-name {
    font-weight: 500;
  }
  .brand-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 3px 8px;
    border: 1px solid var(--grey-40);
    margin-right: 12px;
    color: var(--grey-80);
    vertical-align: middle;
  }
  .pct-val {
    font-size: 18px;
    font-weight: 600;
  }
  .mom-val {
    font-size: 14px;
    font-weight: 500;
    color: var(--grey-80);
  }
  .mom-val.up { color: var(--white); }
  .mom-val.down { color: var(--grey-60); }

  /* inline bar in table */
  .inline-bar-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: flex-end;
  }
  .inline-bar {
    width: 120px;
    height: 4px;
    background: var(--grey-20);
    position: relative;
  }
  .inline-bar .fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: var(--white);
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--delay, 0s);
  }
  .reveal:not(.in) .inline-bar .fill { width: 0 !important; }

  /* ===== CTA ===== */
  .cta-block {
    margin-top: 120px;
    padding: 80px 48px;
    border: 1px solid var(--grey-20);
    text-align: center;
  }
  .cta-block h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 720px;
    margin: 0 auto;
  }
  .cta-block .cta-btn {
    display: inline-block;
    margin-top: 40px;
    padding: 16px 32px;
    background: var(--blue);
    color: var(--white);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.3s ease, background 0.3s ease;
    cursor: pointer;
    border: none;
  }
  .cta-block .cta-btn:hover {
    transform: translateY(-2px);
    background: #0070db;
  }

  footer {
    margin-top: 120px;
    padding-top: 32px;
    border-top: 1px solid var(--grey-20);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey-60);
    flex-wrap: wrap;
    gap: 16px;
  }

  @media (max-width: 840px) {
    .page { padding: 48px 24px 80px; }
    .kpi-grid { grid-template-columns: 1fr; }
    .brand-compare { grid-template-columns: 1fr; }
    .hero-meta { gap: 24px; }
    .brand-block { padding: 40px 28px; }
    .trend-wrap { padding: 24px; }
    .inline-bar { width: 80px; }
  }

  /* ===== UTILITY ===== */
  .blue { color: var(--blue); }
  .red { color: var(--red); }
  .dim { color: var(--grey-40); }
</style>
</head>
